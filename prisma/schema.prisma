generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String?
  businessName  String?
  businessAddress String?
  businessPhone String?
  kvkNumber     String?
  vatNumber     String?
  bankDetails   String?   // IBAN + bank name for invoices
  logoUrl       String?   // base64 encoded logo image
  plan          String    @default("free") // free | pro

  // Invoice defaults
  defaultPaymentTerms String?  @default("net30")
  defaultTaxRate       Float?  @default(21)
  defaultCurrency      String? @default("EUR")
  defaultCountry       String? @default("NL")
  defaultLanguage      String? @default("en")
  invoiceNumberPrefix  String? @default("INV")

  // Notification preferences
  notifyOnView    Boolean? @default(true)
  notifyOnPay     Boolean? @default(true)
  notifyReminders Boolean? @default(false)

  // Email templates
  emailInvoiceSubject  String?
  emailInvoiceMessage  String?
  emailReminderSubject String?
  emailReminderMessage String?

  // Reminder schedule
  reminderFirstDays   Int?     @default(7)
  reminderSecondDays  Int?     @default(3)
  reminderOverdueDays Int?     @default(1)
  remindersEnabled    Boolean? @default(true)
  stripeCustomerId String?
  stripeSubscriptionId String?
  invoiceCount  Int       @default(0) // monthly invoice count
  invoiceResetAt DateTime @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  invoices     Invoice[]
  clients      Client[]
  sessions     Session[]
  serviceItems ServiceItem[]
  expenses       Expense[]
  timeEntries    TimeEntry[]
  mileageEntries MileageEntry[]
  teamMembers    TeamMember[]
  teamMemberships TeamMember[] @relation("MemberUser")
  activeTimer    ActiveTimer?
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Client {
  id        String   @id @default(uuid())
  userId    String
  name      String
  email     String
  phone     String?
  address   String?
  vatNumber String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoices       Invoice[]
  timeEntries    TimeEntry[]
  mileageEntries MileageEntry[]
  activeTimers   ActiveTimer[]
}

model Invoice {
  id            String   @id @default(uuid())
  userId        String
  clientId      String
  invoiceNumber String
  description   String?
  paymentNotes  String?   // bank account, payment instructions
  notesToClient String?   // visible note shown to client on invoice
  serviceDate   DateTime? // date service was performed
  type          String   @default("invoice") // invoice | quote
  status        String   @default("draft") // draft | sent | viewed | paid | overdue
  subtotal      Float    @default(0)
  taxRate       Float    @default(0)
  taxAmount     Float    @default(0)
  total         Float    @default(0)
  currency      String   @default("EUR")
  dueDate       DateTime
  sentAt        DateTime?
  viewedAt      DateTime?
  paidAt        DateTime?
  isRecurring   Boolean  @default(false)
  recurringInterval String? // weekly | monthly | quarterly | yearly
  recurringNextDate DateTime?
  remindersEnabled Boolean @default(true)
  reminder7Sent Boolean  @default(false)
  reminder3Sent Boolean  @default(false)
  reminderOverdueSent Boolean @default(false)
  paymentUrl    String?   // Stripe payment link URL
  reverseCharge Boolean  @default(false)
  referenceInvoice String? // Original invoice number for credit notes
  invoiceTheme  String   @default("classic") // classic | modern | minimal
  invoiceCountry String  @default("NL") // NL, UK, DE, BE
  language      String   @default("en") // en | nl | de
  paidAmount    Float    @default(0) // Partial payment tracking
  scheduledSendAt DateTime? // null = not scheduled, set = will be sent at this time
  depositPercent  Float?    // e.g. 50 for 50%
  depositAmount   Float?    // calculated from total * depositPercent/100
  depositPaid     Boolean   @default(false)
  depositPaidAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  client      Client      @relation(fields: [clientId], references: [id])
  lineItems   LineItem[]
  timeEntries TimeEntry[]
}

model LineItem {
  id          String @id @default(uuid())
  invoiceId   String
  description String
  quantity    Float
  unitPrice   Float
  total       Float

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model ServiceItem {
  id          String   @id @default(uuid())
  userId      String
  name        String
  description String?
  unitPrice   Float
  unit        String   @default("unit") // unit | hour | day | fixed | m² | m
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Expense {
  id            String   @id @default(uuid())
  userId        String
  description   String
  amount        Float
  category      String   // materials, fuel, tools, subcontractor, office, other
  date          DateTime
  receiptUrl    String?  // base64 image of receipt
  vendor        String?  // supplier/shop name
  taxDeductible Boolean  @default(true)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ActiveTimer {
  id          String   @id @default(uuid())
  userId      String   @unique
  startTime   DateTime
  description String   @default("")
  clientId    String?
  hourlyRate  Float    @default(50)
  createdAt   DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  client Client? @relation(fields: [clientId], references: [id])
}

model TimeEntry {
  id          String    @id @default(uuid())
  userId      String
  clientId    String?
  description String
  date        DateTime
  startTime   DateTime?
  endTime     DateTime?
  hours       Float
  hourlyRate  Float
  billable    Boolean   @default(true)
  invoiced    Boolean   @default(false)
  invoiceId   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  client  Client?  @relation(fields: [clientId], references: [id])
  invoice Invoice? @relation(fields: [invoiceId], references: [id])
}

model MileageEntry {
  id           String   @id @default(uuid())
  userId       String
  date         DateTime
  fromLocation String
  toLocation   String
  distance     Float
  purpose      String
  clientId     String?
  ratePerKm    Float    @default(0.23)
  billable     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  client Client? @relation(fields: [clientId], references: [id])
}

model TeamMember {
  id         String    @id @default(uuid())
  userId     String    // team owner
  email      String
  name       String?
  role       String    @default("member") // admin | member
  memberUserId String? // linked user account (after accepting invite)
  inviteToken  String?   @unique
  invitedAt  DateTime  @default(now())
  acceptedAt DateTime?

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  memberUser User?     @relation("MemberUser", fields: [memberUserId], references: [id])

  @@unique([userId, email])
}

